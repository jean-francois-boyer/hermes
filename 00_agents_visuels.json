{
  "schema": "workspace-agents.v3",
  "name": "Agents Workspace visibles",
  "description": "Registre local des agents créés dans le workspace et exposables dans l’interface opérations.",
  "workspace_real_path": "/opt/data/workspace",
  "workspace_ui_path": "/workspace",
  "hermes_home": "/opt/data",
  "profiles_root": "/opt/data/profiles",
  "agents": [
    {
      "id": "minecraft-world-generator-agent",
      "label": "Agent Monde Minecraft Bedrock",
      "type": "hermes-profile",
      "visible": true,
      "status": "ready",
      "profile": "minecraft-world-generator-agent",
      "profile_config": "/opt/data/profiles/minecraft-world-generator-agent/config.yaml",
      "launch_command": "HERMES_HOME=/opt/data hermes --profile minecraft-world-generator-agent",
      "chat_command": "HERMES_HOME=/opt/data hermes --profile minecraft-world-generator-agent chat -q \"Crée un monde Minecraft Bedrock compatible Switch via Realms\"",
      "source_path": "/opt/data/workspace/agent-minecraft-bedrock",
      "ui_path": "/workspace/agent-minecraft-bedrock",
      "entrypoint": "/workspace/agent-minecraft-bedrock/minecraft_agent.py",
      "script": "minecraft_agent.py",
      "capabilities": [
        "world_blueprints",
        "quests",
        "npcs",
        "bedrock_commands",
        "realms_switch_workflow"
      ]
    },
    {
